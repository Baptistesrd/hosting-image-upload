<div class="container py-5">
  <div class="d-flex align-items-center justify-content-between mb-4">
    <h1 class="text-white"><%= @list.name %></h1>
    <div>
      <%= link_to "Add a movie", new_list_bookmark_path(@list), class: "btn btn-warning" %>
      <%= link_to "Back to lists", lists_path, class: "btn btn-warning" %>
    </div>
  </div>

  <div class="row">
    <% @list.movies.each do |movie| %>
      <% bookmark = Bookmark.find_by(list: @list, movie: movie) %>
      <div class="col-12 col-sm-6 mb-3">
        <div class="card-product">
          <img src="<%= movie.poster_url %>" />
          <div class="card-product-infos">
            <h2 class="text-white"><%= movie.title %> <span>• <%= movie.rating %> <i class="fas fa-star text-white"></i></span></h2>
            <p class="text-white"><%= movie.overview %></p>
            <div class="d-flex justify-content-between align-items-end">
              <small><i class="fas fa-quote-left"></i> <%= bookmark.comment %></small>
              <%= link_to "delete", bookmark_path(bookmark), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "btn btn-warning" %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
